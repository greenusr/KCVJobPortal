@model JobPortalKCV.Models.ViewModel.RegisterEmployerViewModel

@{
    ViewBag.Title = "Employer Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container pt-120 pb-120">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="small-section-tittle">
                <h4>Employer Register</h4>
            </div>

            @using (Html.BeginForm("RegisterEmployer", "Account", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="row">
                    <div class="col-md-6 form-group">
                        @Html.LabelFor(model => model.Username)
                        @Html.TextBoxFor(model => model.Username, new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.Username, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6 form-group">
                        @Html.LabelFor(model => model.Email)
                        @Html.TextBoxFor(model => model.Email, new { @class = "form-control", type = "email" })
                        @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6 form-group">
                        @Html.LabelFor(model => model.FirstName)
                        @Html.TextBoxFor(model => model.FirstName, new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.FirstName, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6 form-group">
                        @Html.LabelFor(model => model.LastName)
                        @Html.TextBoxFor(model => model.LastName, new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.LastName, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6 form-group">
                        @Html.LabelFor(model => model.Password)
                        @Html.PasswordFor(model => model.Password, new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6 form-group">
                        @Html.LabelFor(model => model.ConfirmPassword)
                        @Html.PasswordFor(model => model.ConfirmPassword, new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.ConfirmPassword, "", new { @class = "text-danger" })
                    </div>
                </div>

                <hr />

                <div class="form-group employer-company-mode">
                    <label>
                        @Html.CheckBoxFor(model => model.UseExistingCompany)
                        Use an existing company
                    </label>
                </div>

                <div class="row">
                    <div class="col-md-12 form-group existing-company-fields">
                        @Html.LabelFor(model => model.ExistingCompanyId)
                        @Html.DropDownList("ExistingCompanyId", null, "-- Select existing company --", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.ExistingCompanyId, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6 form-group new-company-fields">
                        @Html.LabelFor(model => model.CompanyName)
                        @Html.TextBoxFor(model => model.CompanyName, new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.CompanyName, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6 form-group new-company-fields">
                        @Html.LabelFor(model => model.Industry)
                        @Html.TextBoxFor(model => model.Industry, new { @class = "form-control" })
                    </div>
                    <div class="col-md-6 form-group new-company-fields">
                        @Html.LabelFor(model => model.Website)
                        @Html.TextBoxFor(model => model.Website, new { @class = "form-control" })
                    </div>
                    <div class="col-md-12 form-group new-company-fields">
                        @Html.LabelFor(model => model.Description)
                        @Html.TextAreaFor(model => model.Description, 5, 50, new { @class = "form-control" })
                    </div>
                    <div class="col-md-6 form-group new-company-fields">
                        @Html.LabelFor(model => model.CompanyLogo)
                        <input type="file" name="CompanyLogo" class="form-control" accept="image/*" />
                    </div>
                </div>

                <button type="submit" class="btn">Create Employer Account</button>
                @Html.ActionLink("Choose another type", "Register", null, new { @class = "btn head-btn2" })
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        (function () {
            function syncCompanyMode() {
                var useExisting = document.getElementById("UseExistingCompany").checked;
                var existingFields = document.querySelectorAll(".existing-company-fields");
                var newFields = document.querySelectorAll(".new-company-fields");

                existingFields.forEach(function (field) {
                    field.style.display = useExisting ? "" : "none";
                    field.querySelectorAll("select, input, textarea").forEach(function (input) {
                        input.disabled = !useExisting;
                    });
                });

                newFields.forEach(function (field) {
                    field.style.display = useExisting ? "none" : "";
                    field.querySelectorAll("select, input, textarea").forEach(function (input) {
                        input.disabled = useExisting;
                    });
                });
            }

            document.addEventListener("DOMContentLoaded", function () {
                var checkbox = document.getElementById("UseExistingCompany");
                if (!checkbox) return;
                checkbox.addEventListener("change", syncCompanyMode);
                syncCompanyMode();
            });
        }());
    </script>
}
