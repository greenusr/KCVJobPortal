@model JobPortalKCV.Models.ViewModel.VerifyEmailOtpViewModel

@{
    ViewBag.Title = "Verify Email";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var otpExpirationSeconds = ViewBag.OtpExpirationSeconds == null ? 90 : (int)ViewBag.OtpExpirationSeconds;
}

<div class="page-shell">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="ui-card">
                <div class="small-section-tittle">
                    <h4>Verify Email</h4>
                </div>

                @if (TempData["AuthMessage"] != null)
                {
                    <div class="alert alert-info">@TempData["AuthMessage"]</div>
                }

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="form-group">
                        @Html.LabelFor(model => model.Email)
                        @Html.TextBoxFor(model => model.Email, new { @class = "form-control", type = "email" })
                        @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.OtpCode)
                        @Html.TextBoxFor(model => model.OtpCode, new { @class = "form-control", maxlength = "6" })
                        @Html.ValidationMessageFor(model => model.OtpCode, "", new { @class = "text-danger" })
                    </div>

                    <div class="ui-toolbar">
                        <button type="submit" class="btn">Verify</button>
                        @Html.ActionLink("Back to login", "Login", null, new { @class = "btn head-btn2" })
                    </div>
                }

                @using (Html.BeginForm("ResendRegisterOtp", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.Email)
                    <button type="submit" id="resendOtpButton" class="btn head-btn2 mt-20" disabled>
                        Resend OTP (<span id="otpCountdown">@otpExpirationSeconds</span>s)
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        (function () {
            var seconds = @otpExpirationSeconds;
            var button = document.getElementById("resendOtpButton");
            var countdown = document.getElementById("otpCountdown");

            var timer = window.setInterval(function () {
                seconds -= 1;
                countdown.textContent = seconds;

                if (seconds <= 0) {
                    window.clearInterval(timer);
                    button.disabled = false;
                    button.textContent = "Resend OTP";
                }
            }, 1000);
        })();
    </script>
}
