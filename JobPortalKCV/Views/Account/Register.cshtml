@using JobPortalKCV.Helpers
@{
    ViewBag.Title = UiText.T("Auth.Register");
    Layout = "~/Views/Shared/_Layout.cshtml";
    Func<string, string> T = key => UiText.T(key);
}

<div class="page-shell">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="section-tittle text-center mb-50">
                <span>@T("Auth.CreateAccountEyebrow")</span>
                <h2>@T("Auth.ChooseAccountType")</h2>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="ui-card single-services text-center mb-30">
                        <div class="services-ion">
                            <span class="flaticon-curriculum-vitae"></span>
                        </div>
                        <div class="services-cap">
                            <h5>@T("Auth.Candidate")</h5>
                            <p>@T("Auth.CandidateRegisterText")</p>
                            @Html.ActionLink(T("Auth.RegisterAsCandidate"), "RegisterCandidate", null, new { @class = "btn" })
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="ui-card single-services text-center mb-30">
                        <div class="services-ion">
                            <span class="flaticon-high-tech"></span>
                        </div>
                        <div class="services-cap">
                            <h5>@T("Auth.Employer")</h5>
                            <p>@T("Auth.EmployerRegisterText")</p>
                            @Html.ActionLink(T("Auth.RegisterAsEmployer"), "RegisterEmployer", null, new { @class = "btn head-btn2" })
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-30">
                @Html.ActionLink(T("Auth.AlreadyHaveAccount"), "Login")
            </div>
        </div>
    </div>
</div>
