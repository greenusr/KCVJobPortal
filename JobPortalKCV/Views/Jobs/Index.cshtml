@model IEnumerable<JobPortalKCV.Models.ViewModel.JobViewModel>
@using System.Linq
@using JobPortalKCV.Helpers

@{
    ViewBag.Title = UiText.T("Jobs.Title");
    Layout = "~/Views/Shared/_Layout.cshtml";
    var jobs = Model ?? Enumerable.Empty<JobPortalKCV.Models.ViewModel.JobViewModel>();
    var canManageJobs = AuthRoleHelper.CanManageJobs(User.Identity.Name);
    var totalRecords = ViewBag.TotalRecords == null ? jobs.Count() : (int)ViewBag.TotalRecords;
    Func<string, string> T = key => UiText.T(key);
}

<div class="job-listing-area pt-120 pb-120">
    <div class="container">
        <div class="row mb-35">
            <div class="col-lg-8">
                <div class="section-tittle">
                    <span>@T("Jobs.RecentJobs")</span>
                    <h2>@T("Jobs.FindNext")</h2>
                </div>
            </div>
            @if (canManageJobs)
            {
                <div class="col-lg-4 text-lg-right">
                @Html.ActionLink(T("Button.PostJob"), "Create", new { returnUrl = Request.RawUrl }, new { @class = "btn head-btn2" })
                </div>
            }
        </div>

        <div class="row">
            <div class="col-lg-12">
                @using (Html.BeginForm("Index", "Jobs", FormMethod.Get, new { @class = "mb-35" }))
                {
                    <div class="row">
                        <div class="col-md-3 form-group">
                            <input type="text" name="keyword" class="form-control" value="@ViewBag.Keyword" placeholder="@T("Jobs.Keyword")" />
                        </div>
                        <div class="col-md-2 form-group">
                            @Html.DropDownList("categoryId", ViewBag.Categories as SelectList, T("Jobs.AllCategories"), new { @class = "form-control" })
                        </div>
                        <div class="col-md-2 form-group">
                            @Html.DropDownList("locationId", ViewBag.Locations as SelectList, T("Jobs.AllLocations"), new { @class = "form-control" })
                        </div>
                        <div class="col-md-2 form-group">
                            @Html.DropDownList("skillId", ViewBag.Skills as SelectList, T("Jobs.AllSkills"), new { @class = "form-control" })
                        </div>
                        <div class="col-md-2 form-group">
                            <select name="sort" class="form-control">
                                <option value="newest" @(ViewBag.Sort == "newest" ? "selected" : "")>@T("Jobs.Newest")</option>
                                <option value="oldest" @(ViewBag.Sort == "oldest" ? "selected" : "")>@T("Jobs.Oldest")</option>
                                <option value="star_desc" @(ViewBag.Sort == "star_desc" ? "selected" : "")>@T("Jobs.MostStarred")</option>
                                <option value="star_asc" @(ViewBag.Sort == "star_asc" ? "selected" : "")>@T("Jobs.LeastStarred")</option>
                            </select>
                        </div>
                        <div class="col-md-1 form-group">
                            <button type="submit" class="btn">@T("Button.Filter")</button>
                        </div>
                    </div>
                }

                <div class="count-job mb-35">
                    <span>@UiText.T("Jobs.FoundCount", totalRecords)</span>
                </div>
            </div>
        </div>

        @if (!jobs.Any())
        {
            <div class="ui-empty">
                <h4>@T("Home.NoJobsAvailable")</h4>
                <p>@T("Jobs.NoJobsMatching")</p>
                @if (canManageJobs)
                {
                    <div class="mt-20">
        @Html.ActionLink(T("Button.PostJob"), "Create", new { returnUrl = Request.RawUrl }, new { @class = "btn" })
                    </div>
                }
            </div>
        }
        else
        {
            <div class="listing-grid">
                @foreach (var item in jobs)
                {
                    var postedText = item.posted_date.HasValue ? item.posted_date.Value.ToString("dd/MM/yyyy") : T("Jobs.NotPosted");
                    var logoUrl = String.IsNullOrWhiteSpace(item.logo_path) ? "/img/icon/job-list1.png" : item.logo_path;
                    var canManageThisJob = AuthRoleHelper.CanManageCompany(User.Identity.Name, item.company_id);
                    var detailsUrl = Url.Action("Details", new { id = item.job_id, returnUrl = Request.RawUrl });
                    <article class="listing-card">
                        <div class="listing-card-head">
                            <a class="listing-logo" href="@detailsUrl">
                                <img src="@logoUrl" alt="@item.company_name" />
                            </a>
                            <div>
                                <a class="listing-title" href="@detailsUrl">@item.job_title</a>
                                <div class="listing-subtitle">@item.company_name</div>
                            </div>
                        </div>

                        <div class="listing-card-body">
                            <div class="listing-badges">
                                <span><i class="fas fa-map-marker-alt"></i>@item.location_name</span>
                                <span>@item.salary_range</span>
                                <span>@item.employment_type</span>
                                <span>@UiText.T("Jobs.StarsCount", item.star_count)</span>
                                <span>@postedText</span>
                            </div>
                        </div>

                        <div class="listing-card-actions">
                            @Html.ActionLink(T("Button.ViewDetails"), "Details", new { id = item.job_id, returnUrl = Request.RawUrl }, new { @class = "btn btn-sm" })
                            @using (Html.BeginForm("Toggle", "Stars", FormMethod.Post, new { @class = "listing-inline-form" }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="targetId" value="@item.job_id" />
                                <input type="hidden" name="targetType" value="Job" />
                                <input type="hidden" name="returnUrl" value="@Request.RawUrl" />
                                <button type="submit" class="star-toggle-button @(item.is_starred_by_current_user ? "is-starred" : "")" aria-label="@(item.is_starred_by_current_user ? T("Jobs.UnstarJob") : T("Jobs.StarJob"))" title="@(item.is_starred_by_current_user ? T("Jobs.Unstar") : T("Jobs.Star"))">
                                    <i class="@(item.is_starred_by_current_user ? "fas" : "far") fa-star"></i>
                                </button>
                            }
                            @if (canManageThisJob)
                            {
                                <a class="icon-action-button" href="@Url.Action("Edit", new { id = item.job_id, returnUrl = Request.RawUrl })" aria-label="@T("Button.Edit")" title="@T("Button.Edit")">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a class="icon-action-button icon-action-danger" href="@Url.Action("Delete", new { id = item.job_id, returnUrl = Request.RawUrl })" aria-label="@T("Button.Delete")" title="@T("Button.Delete")">
                                    <i class="fas fa-trash"></i>
                                </a>
                            }
                        </div>
                    </article>
                }
            </div>
        }

        @Html.Partial("_Pagination", (JobPortalKCV.Models.ViewModel.PaginationViewModel)ViewBag.Pagination)
    </div>
</div>
