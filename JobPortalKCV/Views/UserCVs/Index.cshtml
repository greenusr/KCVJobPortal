@model IEnumerable<JobPortalKCV.Models.UserCV>

@{
    ViewBag.Title = "My CVs";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var pagination = (JobPortalKCV.Models.ViewModel.PaginationViewModel)ViewBag.Pagination;
}

<div class="page-shell">
    <div class="container">
    <div class="section-tittle mb-35">
        <span>Candidate</span>
        <h2>My CVs</h2>
    </div>

    @if (TempData["CVMessage"] != null)
    {
        <div class="alert alert-success">@TempData["CVMessage"]</div>
    }
    @if (TempData["CVError"] != null)
    {
        <div class="alert alert-danger">@TempData["CVError"]</div>
    }

    <div class="ui-card">
        <div class="ui-card-title"><h3>Upload CV</h3></div>
        @using (Html.BeginForm("Upload", "UserCVs", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Upload CV</label>
                <input type="file" name="cvFile" class="form-control" accept=".pdf,.doc,.docx" />
                <small class="ui-subtle">PDF, DOC or DOCX. Max 20MB.</small>
            </div>
            <button type="submit" class="btn">Upload CV</button>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="ui-empty">No records found.</div>
    }
    else
    {
        <div class="ui-card">
            <div class="ui-table-wrap">
                <table class="table ui-table">
                    <tr>
                        <th>File</th>
                        <th>Uploaded</th>
                        <th>Default</th>
                        <th></th>
                    </tr>
                    @foreach (var cv in Model)
                    {
                        <tr>
                            <td><a href="@cv.file_path" target="_blank" rel="noopener">@cv.file_name</a></td>
                            <td>@cv.created_at.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="ui-badge @(cv.is_default ? "ui-badge-success" : "ui-badge-muted")">@(cv.is_default ? "Yes" : "No")</span></td>
                            <td>
                                @if (!cv.is_default)
                    {
                        using (Html.BeginForm("SetDefault", "UserCVs", new { id = cv.cv_id, page = pagination.Page }, FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn head-btn2">Set default</button>
                        }
                    }
                            </td>
                        </tr>
                    }
                </table>
            </div>
        </div>
    }

    @Html.Partial("_Pagination", pagination)
    </div>
</div>
