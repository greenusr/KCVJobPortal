    <style>
        .notification-menu {
            display: inline-block;
            position: relative;
            margin-right: 10px;
            vertical-align: middle;
        }

        .notification-toggle {
            color: #1e293b;
            display: inline-block;
            font-size: 18px;
            padding: 8px 10px;
            position: relative;
        }

        .notification-badge {
            background: #3b82f6;
            border-radius: 20px;
            color: #fff;
            font-size: 11px;
            min-width: 18px;
            padding: 1px 5px;
            position: absolute;
            right: 0;
            top: 0;
            text-align: center;
        }

        .notification-dropdown {
            background: #fff;
            border: 1px solid #e6e8ef;
            box-shadow: 0 10px 30px rgba(0, 0, 0, .12);
            display: none;
            position: absolute;
            right: 0;
            top: 38px;
            width: 360px;
            z-index: 9999;
        }

        .notification-menu:hover .notification-dropdown,
        .notification-menu:focus-within .notification-dropdown {
            display: block;
        }

        .notification-dropdown-header,
        .notification-dropdown-footer {
            padding: 12px 15px;
        }

        .notification-dropdown-footer {
            border-top: 1px solid #eef0f5;
            text-align: center;
        }

        .notification-dropdown-list {
            max-height: 360px;
            overflow-y: auto;
        }

        .notification-item {
            border-top: 1px solid #eef0f5;
            color: #1e293b;
            display: block;
            padding: 12px 15px;
        }

        .notification-item:hover {
            background: #f7f8fb;
            color: #1e293b;
        }

        .notification-item.is-unread {
            background: #fff3f7;
            font-weight: 600;
        }

        .notification-item span,
        .notification-item small,
        .notification-item em {
            display: block;
        }

        .notification-item small {
            color: #5f6678;
            font-weight: 400;
            line-height: 1.4;
            margin-top: 4px;
        }

        .notification-item em,
        .notification-empty {
            color: #8a91a4;
            font-size: 12px;
            font-style: normal;
            margin-top: 4px;
        }

        .notification-empty {
            padding: 18px 15px;
        }

        .user-menu {
            display: inline-block;
            position: relative;
            vertical-align: middle;
        }

        .user-menu-toggle {
            cursor: pointer;
        }

        .user-menu .submenu {
            background: #fff;
            border: 1px solid #e6e8ef;
            box-shadow: 0 10px 30px rgba(0, 0, 0, .12);
            display: none;
            min-width: 220px;
            padding: 10px 0;
            position: absolute;
            right: 0;
            top: 100%;
            z-index: 9999;
        }

        .user-menu:hover .submenu,
        .user-menu:focus-within .submenu {
            display: block;
        }

        .user-menu .submenu a {
            color: #1e293b;
            display: block;
            padding: 9px 16px;
            white-space: nowrap;
        }

        .user-menu .submenu a:hover {
            background: #f7f8fb;
            color: #3b82f6;
        }
    </style>
</head>
