<!DOCTYPE html>
@using JobPortalKCV.Helpers
@{
    var isAuthenticated = Request.IsAuthenticated;
    var isAdmin = isAuthenticated && AuthRoleHelper.IsAdmin(User.Identity.Name);
    var isEmployer = isAuthenticated && AuthRoleHelper.IsEmployer(User.Identity.Name);
    var isCandidate = isAuthenticated && AuthRoleHelper.IsCandidate(User.Identity.Name);
    var currentLang = UiText.CurrentLanguage;
    var returnUrl = Request.RawUrl;
    Func<string, string> T = key => UiText.T(key);
    Func<string, string> langUrl = lang => UiText.SwitchUrl(Url, lang, returnUrl);
}
