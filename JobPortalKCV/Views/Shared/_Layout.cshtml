    <script>
        (function () {
            function hidePreloader() {
                var preloader = document.getElementById("preloader-active");
                if (preloader) {
                    preloader.classList.add("is-hidden");
                    setTimeout(function () {
                        preloader.style.display = "none";
                    }, 260);
                }
                document.body.style.overflow = "visible";
            }

            if (document.readyState === "complete") {
                hidePreloader();
            } else {
                window.addEventListener("load", hidePreloader);
                setTimeout(hidePreloader, 1600);
            }
        })();
    </script>
    <script>
        (function () {
            var ticking = false;

            function syncHeaderState() {
                document.body.classList.toggle("site-header-scrolled", window.scrollY > 12);
                ticking = false;
            }

            function requestHeaderSync() {
                if (!ticking) {
                    window.requestAnimationFrame(syncHeaderState);
                    ticking = true;
                }
            }

            syncHeaderState();
            window.addEventListener("scroll", requestHeaderSync, { passive: true });
            window.addEventListener("resize", requestHeaderSync);

            function updateStarButton(button, isStarred) {
                var icon = button.querySelector("i");
                button.classList.toggle("is-starred", isStarred);
                button.setAttribute("aria-label", isStarred ? "@T("Jobs.Unstar")" : "@T("Jobs.Star")");
                button.setAttribute("title", isStarred ? "@T("Jobs.Unstar")" : "@T("Jobs.Star")");

                if (icon) {
                    icon.classList.toggle("fas", isStarred);
                    icon.classList.toggle("far", !isStarred);
                    icon.classList.add("fa-star");
                }
            }

            function updateNearestStarCount(form, count) {
                var card = form.closest(".listing-card, .single-job-items, .post-details3, .post-details4, .col-md-9");
                if (!card || typeof count === "undefined" || count === null) {
                    return;
                }

                var candidates = card.querySelectorAll(".listing-badges span, .job-tittle ul li, p, li");
                for (var i = 0; i < candidates.length; i++) {
                    if (/\bstar\(s\)|\bStars:/i.test(candidates[i].textContent)) {
                        candidates[i].textContent = candidates[i].textContent.replace(/\d+\s*star\(s\)/i, count + " star(s)").replace(/Stars:\s*\d+/i, "Stars: " + count);
                        break;
                    }
                }
            }

            document.addEventListener("submit", function (event) {
                var form = event.target;
                var button = form.querySelector(".star-toggle-button");

                if (!button) {
                    return;
                }

                event.preventDefault();

                if (button.disabled) {
                    return;
                }

                button.disabled = true;
                button.classList.add("is-loading");

                fetch(form.action, {
                    method: "POST",
                    body: new FormData(form),
                    credentials: "same-origin",
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                })
                    .then(function (response) {
                        return response.json().then(function (data) {
                            return { ok: response.ok, data: data };
                        });
                    })
                    .then(function (result) {
                        if (!result.ok || !result.data.success) {
                            if (result.data && result.data.loginUrl) {
                                window.location.href = result.data.loginUrl;
                            }
                            return;
                        }

                        updateStarButton(button, result.data.isStarred);
                        updateNearestStarCount(form, result.data.starCount);
                    })
                    .catch(function () {
                        form.submit();
                    })
                    .finally(function () {
                        button.disabled = false;
                        button.classList.remove("is-loading");
                    });
            });
        })();
    </script>
    <script>
        (function () {
            function enhanceSelectActionLinks() {
                var selects = document.querySelectorAll("select[data-select-action-value][data-select-action-url]");

                Array.prototype.forEach.call(selects, function (select) {
                    var actionValue = select.getAttribute("data-select-action-value");
                    var actionUrl = select.getAttribute("data-select-action-url");
                    var actionLabel = select.getAttribute("data-select-action-label");
                    var niceSelect = select.nextElementSibling;

                    if (!actionValue || !actionUrl || !actionLabel || !niceSelect || niceSelect.className.indexOf("nice-select") < 0) {
                        return;
                    }

                    var list = niceSelect.querySelector(".list");

                    if (!list) {
                        return;
                    }

                    var option = niceSelect.querySelector('.option[data-value="' + actionValue + '"]') || niceSelect.querySelector('.select-action-option[data-action-value="' + actionValue + '"]');

                    if (!option || option.querySelector("a")) {
                        if (!option) {
                            option = document.createElement("li");
                            option.className = "option disabled select-action-option";
                            option.setAttribute("data-action-value", actionValue);
                            list.appendChild(option);
                        }
                        else {
                            option.classList.add("disabled");
                            return;
                        }
                    }

                    if (!option.classList.contains("select-action-option")) {
                        option.classList.add("select-action-option");
                    }

                    option.classList.add("disabled");
                    option.classList.remove("selected", "focus");

                    if (select.value === actionValue) {
                        select.value = "";
                    }

                    var current = niceSelect.querySelector(".current");

                    if (current && current.textContent.trim() === actionLabel.trim()) {
                        var selectedOption = niceSelect.querySelector(".option.selected:not(.select-action-option)");
                        var fallbackOption = niceSelect.querySelector(".option:not(.disabled):not(.select-action-option)");
                        current.textContent = selectedOption ? selectedOption.textContent : (fallbackOption ? fallbackOption.textContent : "");
                    }

                    if (option.querySelector("a")) {
                        return;
                    }

                    option.setAttribute("aria-disabled", "true");
                    var link = document.createElement("a");
                    link.href = actionUrl;
                    link.className = "select-action-link";
                    link.textContent = actionLabel;
                    option.textContent = "";
                    option.appendChild(link);
                });
            }

            document.addEventListener("DOMContentLoaded", enhanceSelectActionLinks);
            window.setTimeout(enhanceSelectActionLinks, 250);

            document.addEventListener("click", function (event) {
                var link = event.target.closest(".select-action-link");

                if (!link) {
                    return;
                }

                event.preventDefault();
                event.stopPropagation();
                window.location.href = link.href;
            }, true);

            document.addEventListener("change", function (event) {
                var select = event.target;

                if (!select || !select.matches("select[data-select-action-value][data-select-action-url]")) {
                    return;
                }

                if (select.value !== select.getAttribute("data-select-action-value")) {
                    return;
                }

                var actionUrl = select.getAttribute("data-select-action-url");
                select.value = "";

                if (window.jQuery && window.jQuery.fn && window.jQuery.fn.niceSelect) {
                    window.jQuery(select).niceSelect("update");
                    enhanceSelectActionLinks();
                }

                if (actionUrl) {
                    window.location.href = actionUrl;
                }
            });
        })();
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>
