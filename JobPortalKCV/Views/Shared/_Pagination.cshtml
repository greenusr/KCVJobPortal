@model JobPortalKCV.Models.ViewModel.PaginationViewModel
@using System
@using System.Web.Routing
@using JobPortalKCV.Helpers

@functions {
    RouteValueDictionary PageRoute(int page)
    {
        var values = Model.RouteValues == null
            ? new RouteValueDictionary()
            : new RouteValueDictionary(Model.RouteValues);

        values["page"] = page;
        return values;
    }
}

@if (Model != null && Model.TotalPages > 1)
{
    var start = Math.Max(1, Model.Page - 2);
    var end = Math.Min(Model.TotalPages, Model.Page + 2);

    <div class="pagination-area pb-115 text-center">
        <div class="container">
            <nav aria-label="Pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        @if (Model.Page <= 1)
                        {
                            <span class="page-link">@UiText.T("Button.Previous")</span>
                        }
                        else
                        {
                            <a class="page-link" href="@Url.Action(Model.ActionName, Model.ControllerName, PageRoute(Model.Page - 1))">@UiText.T("Button.Previous")</a>
                        }
                    </li>

                    @if (start > 1)
                    {
                        <li class="page-item"><a class="page-link" href="@Url.Action(Model.ActionName, Model.ControllerName, PageRoute(1))">1</a></li>
                        if (start > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    @for (var page = start; page <= end; page++)
                    {
                        <li class="page-item @(page == Model.Page ? "active" : "")">
                            @if (page == Model.Page)
                            {
                                <span class="page-link">@page</span>
                            }
                            else
                            {
                                <a class="page-link" href="@Url.Action(Model.ActionName, Model.ControllerName, PageRoute(page))">@page</a>
                            }
                        </li>
                    }

                    @if (end < Model.TotalPages)
                    {
                        if (end < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item"><a class="page-link" href="@Url.Action(Model.ActionName, Model.ControllerName, PageRoute(Model.TotalPages))">@Model.TotalPages</a></li>
                    }

                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                        @if (Model.Page >= Model.TotalPages)
                        {
                            <span class="page-link">@UiText.T("Button.Next")</span>
                        }
                        else
                        {
                            <a class="page-link" href="@Url.Action(Model.ActionName, Model.ControllerName, PageRoute(Model.Page + 1))">@UiText.T("Button.Next")</a>
                        }
                    </li>
                </ul>
                <div class="small text-muted">@UiText.T("Message.PageOfRecords", Model.Page, Model.TotalPages, Model.TotalRecords)</div>
            </nav>
        </div>
    </div>
}
