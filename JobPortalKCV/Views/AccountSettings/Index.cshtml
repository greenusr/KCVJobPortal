@model JobPortalKCV.Models.ViewModel.AccountSettingsViewModel
@using JobPortalKCV.Helpers

@{
    ViewBag.Title = "Account Settings";
    Func<string, string> T = key => UiText.T(key);
    Func<string, string> tabClass = tab => Model.ActiveTab == tab ? "active" : "";
}

<main>
        <div class="page-shell">
            <h2 class="mb-30">Account Settings</h2>

            @if (TempData["AccountSettingsMessage"] != null)
            {
                <div class="alert alert-success">@TempData["AccountSettingsMessage"]</div>
            }
            @if (TempData["AccountSettingsError"] != null)
            {
                <div class="alert alert-danger">@TempData["AccountSettingsError"]</div>
            }

            <ul class="nav nav-tabs mb-30" role="tablist">
                <li class="nav-item"><a class="nav-link @tabClass("account")" href="@Url.Action("Index", new { tab = "account" })">Account</a></li>
                <li class="nav-item"><a class="nav-link @tabClass("security")" href="@Url.Action("Index", new { tab = "security" })">Security</a></li>
                <li class="nav-item"><a class="nav-link @tabClass("notifications")" href="@Url.Action("Index", new { tab = "notifications" })">Notifications</a></li>
                <li class="nav-item"><a class="nav-link @tabClass("privacy")" href="@Url.Action("Index", new { tab = "privacy" })">Privacy</a></li>
                <li class="nav-item"><a class="nav-link @tabClass("login-logs")" href="@Url.Action("Index", new { tab = "login-logs" })">Login Logs</a></li>
                <li class="nav-item"><a class="nav-link @tabClass("activity-logs")" href="@Url.Action("Index", new { tab = "activity-logs" })">Activity Logs</a></li>
            </ul>

            @if (Model.ActiveTab == "account")
            {
                <div class="ui-card">
                    <div class="form-group">
                        <label>Email</label>
                        <input class="form-control" value="@Model.Email" readonly />
                        <small class="form-text text-muted">Email cannot be changed.</small>
                    </div>
                    <div class="form-group">
                        <label>Role</label>
                        <input class="form-control" value="@Model.RoleName" readonly />
                        <small class="form-text text-muted">Role cannot be changed.</small>
                    </div>
                    @if (Model.CreatedAt.HasValue)
                    {
                        <div class="form-group">
                            <label>Created date</label>
                            <input class="form-control" value="@Model.CreatedAt.Value.ToString("yyyy-MM-dd HH:mm")" readonly />
                        </div>
                    }
                </div>
            }

            @if (Model.ActiveTab == "security")
            {
                using (Html.BeginForm("ChangePassword", "AccountSettings", FormMethod.Post, new { @class = "ui-card" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label for="CurrentPassword">Current password</label>
                        <input type="password" name="CurrentPassword" id="CurrentPassword" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label for="NewPassword">New password</label>
                        <input type="password" name="NewPassword" id="NewPassword" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label for="ConfirmPassword">Confirm password</label>
                        <input type="password" name="ConfirmPassword" id="ConfirmPassword" class="form-control" required />
                    </div>
                    <div class="ui-toolbar"><button type="submit" class="btn head-btn2">Save Changes</button></div>
                }
            }

            @if (Model.ActiveTab == "notifications")
            {
                using (Html.BeginForm("UpdateNotifications", "AccountSettings", FormMethod.Post, new { @class = "ui-card" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="form-check mb-2">
                        @Html.CheckBoxFor(model => model.Settings.AppNotificationsEnabled, new { @class = "form-check-input", id = "AppNotificationsEnabled" })
                        <label class="form-check-label" for="AppNotificationsEnabled">In-app notifications</label>
                    </div>
                    <div class="form-check mb-2">
                        @Html.CheckBoxFor(model => model.Settings.JobUpdatesEnabled, new { @class = "form-check-input", id = "JobUpdatesEnabled" })
                        <label class="form-check-label" for="JobUpdatesEnabled">Job updates</label>
                    </div>
                    <div class="form-check mb-2">
                        @Html.CheckBoxFor(model => model.Settings.InterviewNotificationsEnabled, new { @class = "form-check-input", id = "InterviewNotificationsEnabled" })
                        <label class="form-check-label" for="InterviewNotificationsEnabled">Interview notifications</label>
                    </div>
                    <div class="form-check mb-3">
                        @Html.CheckBoxFor(model => model.Settings.InvitationNotificationsEnabled, new { @class = "form-check-input", id = "InvitationNotificationsEnabled" })
                        <label class="form-check-label" for="InvitationNotificationsEnabled">Invitation notifications</label>
                    </div>
                    <div class="ui-toolbar"><button type="submit" class="btn head-btn2">Save Changes</button></div>
                }
            }

            @if (Model.ActiveTab == "privacy")
            {
                using (Html.BeginForm("UpdatePrivacy", "AccountSettings", FormMethod.Post, new { @class = "ui-card" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="form-check mb-3">
                        @Html.CheckBoxFor(model => model.Settings.PublicProfileEnabled, new { @class = "form-check-input", id = "PublicProfileEnabled" })
                        <label class="form-check-label" for="PublicProfileEnabled">Public profile</label>
                    </div>
                    <div class="ui-toolbar"><button type="submit" class="btn head-btn2">Save Changes</button></div>
                }

                if (Model.IsCandidate)
                {
                    using (Html.BeginForm("UpdateCvSettings", "AccountSettings", FormMethod.Post, new { @class = "ui-card" }))
                    {
                        @Html.AntiForgeryToken()
                        <div class="form-check mb-3">
                            @Html.CheckBoxFor(model => model.Settings.ShowCvToEmployers, new { @class = "form-check-input", id = "ShowCvToEmployers" })
                            <label class="form-check-label" for="ShowCvToEmployers">Show CV to employers</label>
                        </div>
                        <div class="form-group">
                            <label for="DefaultCvId">Select Default CV</label>
                            <select name="Settings.DefaultCvId" id="DefaultCvId" class="form-control" data-select-action-value="__add_cv" data-select-action-url="@Url.Action("Index", "UserCVs")" data-select-action-label="+ @T("Button.UploadNewCV")">
                                <option value="">No default CV</option>
                                @foreach (var option in Model.CvOptions)
                                {
                                    <option value="@option.Value" @(option.Selected ? "selected" : "")>@option.Text</option>
                                }
                            </select>
                        </div>
                        <div class="ui-toolbar"><button type="submit" class="btn head-btn2">Save CV Settings</button></div>
                    }
                }
            }

            @if (Model.ActiveTab == "login-logs")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4>Login Logs</h4>
                    @using (Html.BeginForm("DeleteAllLoginLogs", "AccountSettings", FormMethod.Post, new { onsubmit = "return confirm('Delete all login logs?');" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="loginPage" value="@Model.LoginPage" />
                        <button type="submit" class="btn btn-danger btn-sm">Delete All</button>
                    }
                </div>
                <div class="ui-table-wrap account-log-table-wrap">
                    <table class="ui-table account-log-table account-login-log-table">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>IP</th>
                                <th>User Agent</th>
                                <th>Status</th>
                                <th>Failure Reason</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.LoginLogs)
                            {
                                <tr>
                                    <td>@log.LoginTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>@log.IpAddress</td>
                                    <td>@log.UserAgent</td>
                                    <td><span class="ui-badge @(log.IsSuccess ? "ui-badge-success" : "ui-badge-danger")">@(log.IsSuccess ? "Success" : "Failed")</span></td>
                                    <td>@log.FailureReason</td>
                                    <td>
                                        @using (Html.BeginForm("DeleteLoginLog", "AccountSettings", FormMethod.Post, new { onsubmit = "return confirm('Delete this log?');" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@log.LoginLogId" />
                                            <input type="hidden" name="loginPage" value="@Model.LoginPage" />
                                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="ui-pagination">
                    @if (Model.LoginPage > 1)
                    {
                        <a class="btn btn-light" href="@Url.Action("Index", new { tab = "login-logs", loginPage = Model.LoginPage - 1 })">Previous</a>
                    }
                    <span>Page @Model.LoginPage of @Model.LoginTotalPages</span>
                    @if (Model.LoginPage < Model.LoginTotalPages)
                    {
                        <a class="btn btn-light" href="@Url.Action("Index", new { tab = "login-logs", loginPage = Model.LoginPage + 1 })">Next</a>
                    }
                </div>
            }

            @if (Model.ActiveTab == "activity-logs")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4>Activity Logs</h4>
                    @using (Html.BeginForm("DeleteAllActivityLogs", "AccountSettings", FormMethod.Post, new { onsubmit = "return confirm('Delete all activity logs?');" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="activityPage" value="@Model.ActivityPage" />
                        <input type="hidden" name="activityAction" value="@Model.ActivityActionFilter" />
                        <button type="submit" class="btn btn-danger btn-sm">Delete All</button>
                    }
                </div>
                using (Html.BeginForm("Index", "AccountSettings", FormMethod.Get, new { @class = "form-inline mb-3" }))
                {
                    <input type="hidden" name="tab" value="activity-logs" />
                    @Html.DropDownList("activityAction", Model.ActivityActions, new { @class = "form-control mr-2" })
                    <button type="submit" class="btn head-btn2">Filter</button>
                }
                <div class="ui-table-wrap account-log-table-wrap">
                    <table class="ui-table account-log-table account-activity-log-table">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Action</th>
                                <th>Description</th>
                                <th>Keyword</th>
                                <th>Filters</th>
                                <th>Related</th>
                                <th>IP</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.ActivityLogs)
                            {
                                <tr>
                                    <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>@log.Action</td>
                                    <td>@log.Description</td>
                                    <td>@log.Keyword</td>
                                    <td>@log.Filters</td>
                                    <td>@log.RelatedType @log.RelatedId</td>
                                    <td>@log.IpAddress</td>
                                    <td>
                                        @using (Html.BeginForm("DeleteActivityLog", "AccountSettings", FormMethod.Post, new { onsubmit = "return confirm('Delete this log?');" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@log.ActivityLogId" />
                                            <input type="hidden" name="activityPage" value="@Model.ActivityPage" />
                                            <input type="hidden" name="activityAction" value="@Model.ActivityActionFilter" />
                                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="ui-pagination">
                    @if (Model.ActivityPage > 1)
                    {
                        <a class="btn btn-light" href="@Url.Action("Index", new { tab = "activity-logs", activityPage = Model.ActivityPage - 1, activityAction = Model.ActivityActionFilter })">Previous</a>
                    }
                    <span>Page @Model.ActivityPage of @Model.ActivityTotalPages</span>
                    @if (Model.ActivityPage < Model.ActivityTotalPages)
                    {
                        <a class="btn btn-light" href="@Url.Action("Index", new { tab = "activity-logs", activityPage = Model.ActivityPage + 1, activityAction = Model.ActivityActionFilter })">Next</a>
                    }
                </div>
            }
        </div>
</main>
